<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "筆記開示アプリ" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body class="flex min-h-screen flex-col bg-blue-50 text-slate-900">
    <header class="border-b border-blue-200 bg-white shadow-sm">
      <div class="flex w-full items-center justify-between gap-4 px-4 py-3 sm:px-8 lg:px-12">
        <%= link_to root_path, class: "group flex min-w-0 items-center gap-3" do %>
          <span class="shrink-0" aria-hidden="true">
            <%= image_tag "/expressive-writing-logo.png",
                          alt: "",
                          class: "h-14 w-auto" %>
          </span>
          <span class="min-w-0">
            <span class="block truncate text-lg font-bold tracking-tight text-blue-700 group-hover:text-blue-800 sm:text-xl">筆記開示アプリ</span>
            <span class="block truncate text-xs text-slate-500">こころを整える筆記開示</span>
          </span>
        <% end %>

        <nav class="shrink-0" aria-label="メインナビゲーション">
          <%= link_to "ユーザー登録",
                      new_user_path,
                      class: "rounded-lg bg-blue-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2" %>
        </nav>
      </div>
    </header>

    <div class="flex-1">
      <% flash.each do |type, message| %>
        <div class="mx-auto mt-4 max-w-3xl rounded-lg px-4 py-3 text-sm font-medium <%= type == "alert" ? "bg-red-50 text-red-800" : "border border-blue-200 bg-blue-100 text-blue-900" %>"
             role="status">
          <%= message %>
        </div>
      <% end %>
      <%= yield %>
    </div>

    <footer class="border-t border-blue-200 bg-blue-950 text-blue-100">
      <div class="mx-auto max-w-6xl px-4 py-6 text-center text-sm sm:px-6">
        <nav class="flex flex-wrap justify-center gap-x-6 gap-y-2" aria-label="フッターナビゲーション">
          <%= link_to "利用規約", terms_path, class: "transition hover:text-white hover:underline" %>
          <%= link_to "プライバシーポリシー", privacy_path, class: "transition hover:text-white hover:underline" %>
          <%= link_to "お問い合わせ", contact_path, class: "transition hover:text-white hover:underline" %>
        </nav>
        <div class="my-4 border-t border-blue-800"></div>
        <p>&copy; <%= Time.current.year %> 筆記開示アプリ</p>
        <p class="mt-1 text-xs text-blue-300">今日の気持ちを、安心して言葉にできる場所。</p>
      </div>
    </footer>
  </body>
</html>
