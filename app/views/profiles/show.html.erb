<% content_for :title, t(".title") %>

<main class="min-h-[calc(100vh-10rem)] bg-gradient-to-b from-blue-50 to-white px-4 py-12 sm:px-6 sm:py-16">
  <div class="mx-auto max-w-3xl">
    <div>
      <h1 class="text-3xl font-bold tracking-tight text-blue-950 sm:text-4xl">
        <%= t(".heading") %>
      </h1>
    </div>

    <% if @user.errors.any? || @notification_setting.errors.any? %>
      <div id="profile-update-error" class="mt-6 rounded-xl border-2 border-red-400 bg-red-50 p-5 shadow-sm" role="alert" aria-live="assertive">
        <p class="text-lg font-bold text-red-900"><%= t(".update_failed_heading") %></p>
        <p class="mt-1 text-sm leading-6 text-red-800"><%= t(".update_failed_body") %></p>
      </div>
    <% end %>

    <%= form_with model: @user, url: profile_path, method: :patch, class: "mt-10 space-y-8" do |form| %>
      <% notification_border = @notification_setting.errors.any? ? "border-red-300 ring-2 ring-red-100" : "border-blue-100" %>
      <section class="rounded-2xl border <%= notification_border %> bg-white p-6 shadow-sm sm:p-8">
        <div class="flex flex-col gap-6 border-b border-blue-100 pb-8 sm:flex-row sm:items-center">
          <div class="flex h-20 w-20 shrink-0 items-center justify-center rounded-full bg-blue-600 text-2xl font-bold text-white shadow-sm" aria-hidden="true">
            <%= current_user.name.to_s.first.upcase %>
          </div>
          <div>
            <h2 class="text-xl font-bold text-blue-950"><%= current_user.name %></h2>
            <p class="mt-1 text-sm text-slate-600"><%= current_user.email %></p>
          </div>
        </div>

        <% if @user.errors.any? %>
          <div class="mt-8 rounded-lg border border-red-200 bg-red-50 p-4" role="alert">
            <p class="font-semibold text-red-800"><%= t(".error_heading") %></p>
            <ul class="mt-2 list-disc space-y-1 pl-5 text-sm text-red-700">
              <% @user.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="mt-8 space-y-6">
          <div>
            <%= form.label :name, t(".name_label"), class: "block text-sm font-medium text-blue-950" %>
            <%= form.text_field :name,
                                required: true,
                                maxlength: 50,
                                autocomplete: "name",
                                class: "mt-2 block w-full rounded-lg border border-blue-200 bg-blue-50/40 px-3 py-2 text-slate-900 shadow-sm outline-none transition focus:border-blue-500 focus:bg-white focus:ring-2 focus:ring-blue-200" %>
            <p class="mt-1 text-xs text-slate-500"><%= t(".name_hint") %></p>
          </div>

          <div>
            <%= form.label :email, t(".email_label"), class: "block text-sm font-medium text-blue-950" %>
            <%= form.email_field :email,
                                 required: true,
                                 autocomplete: "email",
                                 class: "mt-2 block w-full rounded-lg border border-blue-200 bg-blue-50/40 px-3 py-2 text-slate-900 shadow-sm outline-none transition focus:border-blue-500 focus:bg-white focus:ring-2 focus:ring-blue-200" %>
          </div>

          <div>
            <%= label_tag :masked_password, t(".password_label"), class: "block text-sm font-medium text-blue-950" %>
            <%= password_field_tag :masked_password,
                                   "********",
                                   disabled: true,
                                   class: "mt-2 block w-full rounded-lg border border-blue-200 bg-slate-100 px-3 py-2 text-slate-500 shadow-sm" %>
            <p class="mt-1 text-xs text-slate-500"><%= t(".password_display_hint") %></p>
          </div>

          <div class="rounded-xl border border-blue-100 bg-blue-50/50 p-4">
            <h2 class="text-sm font-semibold text-blue-950"><%= t(".password_change_heading") %></h2>
            <p class="mt-1 text-xs text-slate-600"><%= t(".password_change_hint") %></p>

            <div class="mt-4 space-y-4">
              <div>
                <%= form.label :password, t(".new_password_label"), class: "block text-sm font-medium text-blue-950" %>
                <%= form.password_field :password,
                                        minlength: 8,
                                        autocomplete: "new-password",
                                        class: "mt-2 block w-full rounded-lg border border-blue-200 bg-white px-3 py-2 text-slate-900 shadow-sm outline-none transition focus:border-blue-500 focus:ring-2 focus:ring-blue-200" %>
              </div>

              <div>
                <%= form.label :password_confirmation, t(".password_confirmation_label"), class: "block text-sm font-medium text-blue-950" %>
                <%= form.password_field :password_confirmation,
                                        minlength: 8,
                                        autocomplete: "new-password",
                                        class: "mt-2 block w-full rounded-lg border border-blue-200 bg-white px-3 py-2 text-slate-900 shadow-sm outline-none transition focus:border-blue-500 focus:ring-2 focus:ring-blue-200" %>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="rounded-2xl border border-blue-100 bg-white p-6 shadow-sm sm:p-8">
        <div>
          <h2 class="text-2xl font-bold tracking-tight text-blue-950"><%= t(".notification_heading") %></h2>
          <p class="mt-2 text-sm leading-7 text-slate-600"><%= t(".notification_description") %></p>
        </div>

        <% unless @line_notifications_enabled %>
          <div class="mt-6 rounded-xl border border-amber-200 bg-amber-50 p-4" role="status">
            <p class="font-semibold text-amber-900"><%= t(".line_notification_disabled_heading") %></p>
            <p class="mt-1 text-sm leading-6 text-amber-800"><%= t(".line_notification_disabled_body") %></p>
          </div>
        <% end %>

        <% if @notification_setting.errors.any? %>
          <div class="mt-8 rounded-lg border border-red-200 bg-red-50 p-4" role="alert">
            <p class="font-semibold text-red-800"><%= t(".notification_error_heading") %></p>
            <ul class="mt-2 list-disc space-y-1 pl-5 text-sm text-red-700">
              <% @notification_setting.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <%= fields_for :notification_setting, @notification_setting do |notification_form| %>
          <div class="mt-8 space-y-7">
            <div class="rounded-xl border border-blue-100 bg-blue-50/60 p-5">
              <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
                <div>
                  <%= notification_form.label :notification_enabled,
                                              t(".notification_enabled_label"),
                                              class: "block text-base font-semibold text-blue-950" %>
                  <p class="mt-1 text-sm leading-6 text-slate-600"><%= t(".notification_enabled_hint") %></p>
                </div>
                <label class="inline-flex cursor-pointer items-center gap-3 rounded-full bg-white px-4 py-2 text-sm font-semibold text-blue-900 shadow-sm ring-1 ring-blue-100">
                  <%= notification_form.check_box :notification_enabled,
                                                  class: "h-5 w-5 rounded border-blue-300 text-blue-600 focus:ring-blue-500" %>
                  <span><%= t(".notification_enabled_switch") %></span>
                </label>
              </div>
            </div>

            <% reminder_days_invalid = @notification_setting.errors[:reminder_days].any? %>
            <% reminder_days_style = reminder_days_invalid ? "border-red-400 bg-red-50" : "border-transparent" %>
            <fieldset class="rounded-xl border p-4 <%= reminder_days_style %>" aria-invalid="<%= reminder_days_invalid %>">
              <legend class="block text-sm font-medium text-blue-950">
                <%= t(".reminder_days_label") %>
              </legend>
              <p class="mt-1 text-xs <%= reminder_days_invalid ? "text-red-700" : "text-slate-500" %>"><%= t(".reminder_days_hint") %></p>

              <div class="mt-3 grid grid-cols-2 gap-3 sm:grid-cols-4">
                <%= notification_form.collection_check_boxes(
                      :reminder_days,
                      NotificationSetting::VALID_REMINDER_DAYS,
                      :itself,
                      ->(day) { t(".reminder_day_names.day_#{day}") }
                    ) do |day_field| %>
                  <%= day_field.label(class: "flex cursor-pointer items-center gap-2 rounded-lg border border-blue-100 bg-blue-50/40 px-3 py-2 text-sm font-medium text-blue-950") do %>
                    <%= day_field.check_box(
                          class: "h-4 w-4 rounded border-blue-300 text-blue-600 focus:ring-blue-500",
                          aria: { invalid: reminder_days_invalid }
                        ) %>
                    <span><%= day_field.text %></span>
                  <% end %>
                <% end %>
              </div>

              <% if reminder_days_invalid %>
                <p class="mt-3 font-semibold text-red-800"><%= @notification_setting.errors.full_messages_for(:reminder_days).join("、") %></p>
              <% end %>
            </fieldset>

            <div>
              <%= notification_form.label :notification_time,
                                          t(".notification_time_label"),
                                          class: "block text-sm font-medium text-blue-950" %>
              <%= notification_form.time_field :notification_time,
                                               value: @notification_setting.notification_time&.strftime("%H:%M"),
                                               required: true,
                                               class: "mt-2 block w-full rounded-lg border border-blue-200 bg-blue-50/40 px-3 py-2 text-slate-900 shadow-sm outline-none transition focus:border-blue-500 focus:bg-white focus:ring-2 focus:ring-blue-200 sm:w-48" %>
              <p class="mt-1 text-xs text-slate-500"><%= t(".notification_time_hint") %></p>
            </div>

            <div class="rounded-xl border border-blue-100 bg-white p-5">
              <h3 class="text-sm font-semibold text-blue-950"><%= t(".line_notice_heading") %></h3>
              <p class="mt-2 text-sm leading-6 text-slate-600"><%= t(".line_notice_body") %></p>
            </div>
          </div>
        <% end %>
      </section>

      <%= form.submit t(".submit"),
                      class: "w-full cursor-pointer rounded-lg bg-blue-600 px-4 py-3 font-semibold text-white shadow-sm transition hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2" %>
    <% end %>

    <section class="mt-8 rounded-2xl border border-blue-100 bg-white p-6 shadow-sm sm:p-8">
      <h2 class="text-2xl font-bold tracking-tight text-blue-950"><%= t(".line_connection_heading") %></h2>

      <% if @line_connection&.linked? %>
        <span class="mt-4 inline-flex rounded-full bg-green-100 px-3 py-1 text-sm font-semibold text-green-800"><%= t(".line_connected") %></span>
        <p class="mt-3 text-sm leading-6 text-slate-600"><%= t(@line_notifications_enabled ? ".line_connected_description" : ".line_connected_disabled_description") %></p>
        <% if @line_notifications_enabled %>
          <p class="mt-2 text-sm text-slate-500">
            <% if @line_connection.last_notified_at? %>
              <%= t(".line_last_notified_at", datetime: l(@line_connection.last_notified_at, format: :short)) %>
            <% else %>
              <%= t(".line_never_notified") %>
            <% end %>
          </p>
          <%= button_to t(".line_test_submit"),
                        line_notification_path,
                        method: :post,
                        form_class: "mt-5",
                        class: "w-full cursor-pointer rounded-lg border border-blue-600 bg-white px-4 py-3 font-semibold text-blue-700 shadow-sm transition hover:bg-blue-50 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2",
                        data: { turbo_submits_with: t(".line_test_sending") } %>
        <% else %>
          <div class="mt-5 rounded-xl border border-amber-200 bg-amber-50 p-4" role="status">
            <p class="font-semibold text-amber-900"><%= t(".line_notification_disabled_heading") %></p>
            <p class="mt-1 text-sm leading-6 text-amber-800"><%= t(".line_notification_disabled_body") %></p>
          </div>
        <% end %>
        <%= button_to t(".line_disconnect_submit"),
                      line_connection_path,
                      method: :delete,
                      form_class: "mt-3",
                      class: "w-full cursor-pointer rounded-lg bg-red-600 px-4 py-3 font-semibold text-white shadow-sm transition hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2",
                      data: { turbo_confirm: t(".line_disconnect_confirm") } %>
      <% elsif @line_connection&.blocked? %>
        <span class="mt-4 inline-flex rounded-full bg-red-100 px-3 py-1 text-sm font-semibold text-red-800"><%= t(".line_blocked") %></span>
        <p class="mt-3 text-sm leading-6 text-slate-600"><%= t(".line_blocked_description") %></p>
        <%= button_to t(".line_disconnect_submit"),
                      line_connection_path,
                      method: :delete,
                      form_class: "mt-5",
                      class: "w-full cursor-pointer rounded-lg bg-red-600 px-4 py-3 font-semibold text-white shadow-sm transition hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2",
                      data: { turbo_confirm: t(".line_disconnect_confirm") } %>
      <% else %>
        <span class="mt-4 inline-flex rounded-full bg-slate-100 px-3 py-1 text-sm font-semibold text-slate-700"><%= t(".line_not_connected") %></span>
        <p class="mt-3 text-sm leading-6 text-slate-600"><%= t(".line_not_connected_description") %></p>
        <%= link_to t(".line_connect_submit"),
                    new_line_connection_path,
                    class: "mt-5 block w-full rounded-lg bg-[#06c755] px-4 py-3 text-center font-semibold text-white shadow-sm transition hover:bg-[#05b84d] focus:outline-none focus:ring-2 focus:ring-green-500 focus:ring-offset-2",
                    data: { turbo: false } %>
      <% end %>
    </section>
  </div>
</main>
