<% content_for :title, t(".title") %>

<main class="min-h-[calc(100vh-10rem)] bg-gradient-to-b from-blue-50 to-white px-4 py-12 sm:px-6 sm:py-16">
  <div class="mx-auto max-w-3xl">
    <div>
      <h1 class="text-3xl font-bold tracking-tight text-blue-950 sm:text-4xl">
        <%= t(".heading") %>
      </h1>
    </div>

    <section class="mt-10 rounded-2xl border border-blue-100 bg-white p-6 shadow-sm sm:p-8">
      <div class="flex flex-col gap-6 sm:flex-row sm:items-center">
        <div class="flex h-20 w-20 shrink-0 items-center justify-center rounded-full bg-blue-600 text-2xl font-bold text-white shadow-sm" aria-hidden="true">
          <%= current_user.name.to_s.first.upcase %>
        </div>
        <div>
          <h2 class="text-xl font-bold text-blue-950"><%= current_user.name %></h2>
          <p class="mt-1 text-sm text-slate-600"><%= current_user.email %></p>
        </div>
      </div>

      <dl class="mt-8 divide-y divide-blue-100 border-y border-blue-100">
        <div class="py-4 sm:grid sm:grid-cols-3 sm:gap-4">
          <dt class="text-sm font-semibold text-blue-950"><%= t(".name") %></dt>
          <dd class="mt-1 text-sm text-slate-700 sm:col-span-2 sm:mt-0"><%= current_user.name %></dd>
        </div>
        <div class="py-4 sm:grid sm:grid-cols-3 sm:gap-4">
          <dt class="text-sm font-semibold text-blue-950"><%= t(".email") %></dt>
          <dd class="mt-1 text-sm text-slate-700 sm:col-span-2 sm:mt-0"><%= current_user.email %></dd>
        </div>
      </dl>
    </section>
  </div>
</main>
