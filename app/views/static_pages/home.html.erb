<% content_for :title, t(".title") %>

<main>
  <section class="bg-gradient-to-b from-blue-50 via-white to-blue-50 px-4 py-16 sm:px-6 sm:py-24">
    <div class="mx-auto max-w-4xl text-center">
      <p class="text-sm font-semibold tracking-wide text-blue-600"><%= t(".eyebrow") %></p>
      <h1 class="mt-4 text-4xl font-bold tracking-tight text-blue-950 sm:text-5xl">
        <%= t(".heading") %>
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-base leading-8 text-slate-600 sm:text-lg">
        <%= t(".description") %>
      </p>
      <div class="mt-10">
        <%= link_to t(".signup"),
                    new_user_path,
                    class: "inline-flex rounded-xl bg-blue-600 px-7 py-3 text-base font-semibold text-white shadow-lg shadow-blue-200 transition hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2" %>
      </div>
    </div>
  </section>

  <section class="bg-white px-4 py-14 sm:px-6">
    <div class="mx-auto grid max-w-5xl gap-6 md:grid-cols-3">
      <% %i[private guided reflection].each do |feature| %>
        <div class="rounded-2xl border border-blue-100 bg-blue-50/60 p-6">
          <h2 class="text-lg font-semibold text-blue-900"><%= t(".features.#{feature}.title") %></h2>
          <p class="mt-3 text-sm leading-7 text-slate-600"><%= t(".features.#{feature}.description") %></p>
        </div>
      <% end %>
    </div>
  </section>
</main>
