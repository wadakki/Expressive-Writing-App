<% content_for :title, t(".title") %>

<main class="mx-auto w-full max-w-3xl px-4 py-12 sm:px-6">
  <article class="rounded-2xl bg-white p-6 shadow-sm ring-1 ring-blue-200 sm:p-10">
    <h1 class="text-3xl font-bold text-blue-950"><%= t(".title") %></h1>
    <p class="mt-3 text-sm text-slate-500"><%= t(".introduction") %></p>

    <div class="mt-8 space-y-7 text-sm leading-7 text-slate-700">
      <% %i[collection purpose sharing security].each do |section| %>
        <section>
          <h2 class="text-lg font-semibold text-blue-900"><%= t(".sections.#{section}.title") %></h2>
          <p class="mt-2"><%= t(".sections.#{section}.body") %></p>
        </section>
      <% end %>
    </div>
  </article>
</main>
