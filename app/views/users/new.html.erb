<% content_for :title, "ユーザー登録" %>

<main class="bg-gradient-to-b from-blue-50 to-white px-4 py-12 sm:py-16">
  <div class="mx-auto max-w-md rounded-2xl bg-white p-8 shadow-xl shadow-blue-100 ring-1 ring-blue-200">
    <div class="mb-8 text-center">
      <p class="text-sm font-semibold text-blue-600">アカウントを作成</p>
      <h1 class="mt-2 text-3xl font-bold tracking-tight text-blue-950">ユーザー登録</h1>
      <p class="mt-3 text-sm text-slate-600">筆記開示を始めるためのアカウントを作成します。</p>
    </div>

    <% if @user.errors.any? %>
      <div class="mb-6 rounded-lg border border-red-200 bg-red-50 p-4" role="alert">
        <p class="font-semibold text-red-800">入力内容を確認してください</p>
        <ul class="mt-2 list-disc space-y-1 pl-5 text-sm text-red-700">
          <% @user.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= form_with model: @user, class: "space-y-5" do |form| %>
      <div>
        <%= form.label :name, "名前", class: "block text-sm font-medium text-blue-950" %>
        <%= form.text_field :name,
                            required: true,
                            autocomplete: "name",
                            class: "mt-2 block w-full rounded-lg border border-blue-200 bg-blue-50/40 px-3 py-2 text-slate-900 shadow-sm outline-none transition focus:border-blue-500 focus:bg-white focus:ring-2 focus:ring-blue-200" %>
        <p class="mt-1 text-xs text-slate-500">50文字以内で入力してください。</p>
      </div>

      <div>
        <%= form.label :email, "メールアドレス", class: "block text-sm font-medium text-blue-950" %>
        <%= form.email_field :email,
                             required: true,
                             autocomplete: "email",
                             class: "mt-2 block w-full rounded-lg border border-blue-200 bg-blue-50/40 px-3 py-2 text-slate-900 shadow-sm outline-none transition focus:border-blue-500 focus:bg-white focus:ring-2 focus:ring-blue-200" %>
      </div>

      <div>
        <%= form.label :password, "パスワード", class: "block text-sm font-medium text-blue-950" %>
        <%= form.password_field :password,
                                required: true,
                                minlength: 8,
                                autocomplete: "new-password",
                                class: "mt-2 block w-full rounded-lg border border-blue-200 bg-blue-50/40 px-3 py-2 text-slate-900 shadow-sm outline-none transition focus:border-blue-500 focus:bg-white focus:ring-2 focus:ring-blue-200" %>
        <p class="mt-1 text-xs text-slate-500">8文字以上で入力してください。</p>
      </div>

      <div>
        <%= form.label :password_confirmation, "パスワード（確認）", class: "block text-sm font-medium text-blue-950" %>
        <%= form.password_field :password_confirmation,
                                required: true,
                                minlength: 8,
                                autocomplete: "new-password",
                                class: "mt-2 block w-full rounded-lg border border-blue-200 bg-blue-50/40 px-3 py-2 text-slate-900 shadow-sm outline-none transition focus:border-blue-500 focus:bg-white focus:ring-2 focus:ring-blue-200" %>
      </div>

      <%= form.submit "登録する",
                      class: "w-full cursor-pointer rounded-lg bg-blue-600 px-4 py-3 font-semibold text-white shadow-sm transition hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2" %>
    <% end %>
  </div>
</main>
