<% timer_enabled = local_assigns.fetch(:show_timer, false) %>
<% timer_duration = WritingEntry::TIMER_DURATION_SECONDS %>
<% timer_remaining_seconds = writing_entry.timer_remaining_seconds || timer_duration %>
<% timer_remaining_seconds = timer_remaining_seconds.clamp(0, timer_duration) %>

<%= form_with model: writing_entry,
              class: "space-y-8",
              data: (timer_enabled ? { controller: "writing-timer",
                                       writing_timer_duration_value: timer_duration,
                                       writing_timer_initial_remaining_value: timer_remaining_seconds,
                                       writing_timer_alert_message_value: t("writing_entries.form.timer.alert") } : {}) do |form| %>
  <% if writing_entry.errors.any? %>
    <div class="rounded-lg border border-red-200 bg-red-50 p-4 text-red-800" role="alert">
      <h2 class="font-semibold"><%= error_heading %></h2>
      <ul class="mt-2 list-disc space-y-1 pl-5 text-sm">
        <% writing_entry.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <% if timer_enabled %>
    <section class="sticky top-4 z-20 rounded-xl border border-blue-200 bg-blue-50/95 p-5 shadow-lg shadow-blue-100 backdrop-blur"
             data-writing-timer-target="container">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <h2 class="text-lg font-semibold text-blue-950"><%= t("writing_entries.form.timer.heading") %></h2>
          <p class="mt-1 text-sm text-slate-600"><%= t("writing_entries.form.timer.description") %></p>
        </div>
        <div class="rounded-2xl bg-white px-5 py-3 text-center shadow-sm ring-1 ring-blue-100">
          <p class="text-xs font-semibold text-blue-600"><%= t("writing_entries.form.timer.remaining") %></p>
          <output class="mt-1 block text-3xl font-bold tabular-nums text-blue-950"
                  data-writing-timer-target="display"
                  aria-live="polite"><%= "#{timer_remaining_seconds / 60}:#{format('%02d', timer_remaining_seconds % 60)}" %></output>
        </div>
      </div>
      <%= form.hidden_field :timer_remaining_seconds,
                            value: timer_remaining_seconds,
                            data: { writing_timer_target: "remainingField" } %>
      <div class="mt-5 h-2 overflow-hidden rounded-full bg-white ring-1 ring-blue-100">
        <div class="h-full rounded-full bg-blue-600 transition-all duration-500"
             data-writing-timer-target="progress"
             style="width: <%= (timer_remaining_seconds.to_f / timer_duration * 100).round(2) %>%"></div>
      </div>
      <p class="mt-4 hidden rounded-lg border border-amber-200 bg-white px-4 py-3 text-sm font-semibold text-amber-800"
         data-writing-timer-target="timeoutMessage"
         role="status"><%= t("writing_entries.form.timer.finished") %></p>
    </section>
  <% end %>

  <section class="rounded-xl bg-blue-50 p-5">
    <h2 class="text-lg font-semibold text-blue-950"><%= t("writing_entries.form.before_happiness.heading") %></h2>
    <p class="mt-1 text-sm text-slate-600"><%= t("writing_entries.form.before_happiness.description") %></p>
    <%= form.label :before_happiness_score,
                   t("writing_entries.form.before_happiness.label"),
                   class: "mt-4 block text-sm font-medium text-blue-950" %>
    <%= form.number_field :before_happiness_score,
                          min: 1,
                          max: 10,
                          step: 1,
                          required: true,
                          class: "mt-2 block w-full rounded-lg border border-blue-200 bg-white px-3 py-2 text-slate-900 shadow-sm outline-none transition focus:border-blue-500 focus:ring-2 focus:ring-blue-200 sm:w-32" %>
  </section>

  <% [
    [:event_detail, "event"],
    [:negative_emotion_detail, "negative_emotion"],
    [:positive_emotion_detail, "positive_emotion"],
    [:unforgiven_target_detail, "unforgiven_target"],
    [:tomorrow_hope, "tomorrow_hope"]
  ].each_with_index do |(attribute, question), index| %>
    <section>
      <%= form.label attribute,
                     class: "block text-base font-semibold leading-7 text-blue-950" do %>
        <span class="mr-2 inline-flex h-7 w-7 items-center justify-center rounded-full bg-blue-600 text-sm text-white">
          <%= index + 1 %>
        </span>
        <%= t("writing_entries.form.questions.#{question}") %>
      <% end %>
      <%= form.text_area attribute,
                         rows: 7,
                         maxlength: 3000,
                         required: true,
                         class: "mt-3 block w-full rounded-lg border border-blue-200 bg-blue-50/30 px-3 py-3 text-slate-900 shadow-sm outline-none transition focus:border-blue-500 focus:bg-white focus:ring-2 focus:ring-blue-200" %>
      <p class="mt-1 text-right text-xs text-slate-500"><%= t("writing_entries.form.character_limit") %></p>
    </section>
  <% end %>

  <section class="rounded-xl bg-blue-50 p-5">
    <h2 class="text-lg font-semibold text-blue-950"><%= t("writing_entries.form.after_happiness.heading") %></h2>
    <p class="mt-1 text-sm text-slate-600"><%= t("writing_entries.form.after_happiness.description") %></p>
    <%= form.label :after_happiness_score,
                   t("writing_entries.form.after_happiness.label"),
                   class: "mt-4 block text-sm font-medium text-blue-950" %>
    <%= form.number_field :after_happiness_score,
                          min: 1,
                          max: 10,
                          step: 1,
                          required: true,
                          class: "mt-2 block w-full rounded-lg border border-blue-200 bg-white px-3 py-2 text-slate-900 shadow-sm outline-none transition focus:border-blue-500 focus:ring-2 focus:ring-blue-200 sm:w-32" %>
  </section>

  <div class="grid gap-3 <%= show_draft_button ? "sm:grid-cols-2" : "" %>">
    <% if show_draft_button %>
      <%= form.button t("writing_entries.form.save_draft"),
                      name: "writing_entry[status]",
                      value: "draft",
                      formnovalidate: true,
                      class: "w-full cursor-pointer rounded-lg border border-blue-600 bg-white px-4 py-3 font-semibold text-blue-700 transition hover:bg-blue-50 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2" %>
    <% end %>
    <%= form.button submit_label,
                    name: "writing_entry[status]",
                    value: "completed",
                    data: (timer_enabled ? { writing_timer_target: "completedButton" } : {}),
                    class: "w-full cursor-pointer rounded-lg bg-blue-600 px-4 py-3 font-semibold text-white shadow-sm transition hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 disabled:hover:bg-blue-600" %>
  </div>
<% end %>
