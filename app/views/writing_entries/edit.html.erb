<% content_for :title, t(".title") %>

<main class="bg-gradient-to-b from-blue-50 to-white px-4 py-12 sm:py-16">
  <div class="mx-auto max-w-3xl rounded-2xl bg-white p-6 shadow-xl shadow-blue-100 ring-1 ring-blue-200 sm:p-10">
    <div class="mb-10 text-center">
      <p class="text-sm font-semibold text-blue-600"><%= t(".eyebrow") %></p>
      <h1 class="mt-2 text-3xl font-bold tracking-tight text-blue-950"><%= t(".heading") %></h1>
      <p class="mx-auto mt-3 max-w-2xl text-sm leading-7 text-slate-600"><%= t(".description") %></p>
    </div>

    <%= render "form",
               writing_entry: @writing_entry,
               error_heading: t(".error_heading"),
               submit_label: t(".submit"),
               show_draft_button: @writing_entry.draft?,
               show_timer: @writing_entry.draft? %>

    <%= link_to t(".cancel"), @writing_entry.completed? ? @writing_entry : writing_entries_path, class: "mt-6 block text-center text-sm font-semibold text-blue-700 hover:text-blue-900" %>
    <% if @writing_entry.draft? %>
      <%= link_to t("writing_entries.destroy.link"),
                  @writing_entry,
                  data: { turbo_method: :delete, turbo_confirm: t("writing_entries.destroy.confirm") },
                  class: "mt-4 block rounded-lg bg-red-600 px-4 py-2 text-center text-sm font-semibold text-white transition hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2" %>
    <% end %>
  </div>
</main>
