<% content_for :title, t(".title") %>

<main class="min-h-[calc(100vh-10rem)] bg-gradient-to-b from-blue-50 to-white px-4 py-12 sm:px-6 sm:py-16">
  <div class="mx-auto max-w-5xl">
    <div class="flex flex-col gap-5 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="text-sm font-semibold tracking-wide text-blue-600"><%= t(".eyebrow") %></p>
        <h1 class="mt-2 text-3xl font-bold tracking-tight text-blue-950 sm:text-4xl">
          <%= t(".heading") %>
        </h1>
        <p class="mt-3 text-sm leading-7 text-slate-600"><%= t(".description") %></p>
      </div>
      <%= link_to t(".new_writing_entry"),
                  new_writing_entry_path,
                  class: "inline-flex shrink-0 justify-center rounded-lg bg-blue-600 px-5 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2" %>
    </div>

    <% if @writing_entries.any? %>
      <div class="mt-10 space-y-5">
        <% @writing_entries.each do |writing_entry| %>
          <article id="<%= dom_id(writing_entry) %>" class="rounded-2xl border border-blue-100 bg-white p-6 shadow-sm">
            <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
              <time datetime="<%= writing_entry.created_at.iso8601 %>" class="text-sm font-semibold text-blue-700">
                <%= l(writing_entry.created_at, format: :long) %>
              </time>
              <div class="flex flex-wrap items-center gap-3">
                <span class="rounded-full px-3 py-1 text-xs font-semibold <%= writing_entry.completed? ? "bg-blue-100 text-blue-800" : "bg-amber-100 text-amber-800" %>">
                  <%= t(".statuses.#{writing_entry.status}") %>
                </span>
                <% if writing_entry.completed? %>
                  <div class="flex items-center gap-2 text-sm text-slate-600">
                    <span><%= t(".before_happiness", score: writing_entry.before_happiness_score) %></span>
                    <span aria-hidden="true">→</span>
                    <span class="font-semibold text-blue-800">
                      <%= t(".after_happiness", score: writing_entry.after_happiness_score) %>
                    </span>
                  </div>
                <% end %>
              </div>
            </div>
            <div class="mt-5 border-t border-blue-100 pt-5">
              <h2 class="text-sm font-semibold text-blue-950"><%= t(".event_heading") %></h2>
              <p class="mt-2 whitespace-pre-wrap break-words text-sm leading-7 text-slate-700">
                <% if writing_entry.event_detail.present? %>
                  <%= writing_entry.event_detail %>
                <% else %>
                  <span class="text-slate-500"><%= t(".blank_draft") %></span>
                <% end %>
              </p>
            </div>
            <div class="mt-5 flex flex-col gap-3 text-right sm:flex-row sm:justify-end">
              <% if writing_entry.completed? %>
                <%= link_to t(".show"),
                            writing_entry_path(writing_entry),
                            class: "inline-flex items-center text-sm font-semibold text-blue-700 transition hover:text-blue-900 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2" %>
              <% else %>
                <%= link_to t(".resume_edit"),
                            edit_writing_entry_path(writing_entry),
                            class: "inline-flex items-center text-sm font-semibold text-blue-700 transition hover:text-blue-900 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2" %>
              <% end %>
              <%= link_to t("writing_entries.destroy.link"),
                          writing_entry,
                          data: { turbo_method: :delete, turbo_confirm: t("writing_entries.destroy.confirm") },
                          class: "inline-flex items-center text-sm font-semibold text-red-700 transition hover:text-red-900 focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2" %>
            </div>
          </article>
        <% end %>
      </div>
    <% else %>
      <div class="mt-10 rounded-2xl border border-dashed border-blue-200 bg-white px-6 py-14 text-center">
        <h2 class="text-lg font-semibold text-blue-950"><%= t(".empty_heading") %></h2>
        <p class="mt-2 text-sm text-slate-600"><%= t(".empty_description") %></p>
      </div>
    <% end %>
  </div>
</main>
